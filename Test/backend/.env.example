DB_HOST=filmhub-db.internal.delightfuldune-f7916078.francecentral.azurecontainerapps.io
DB_PORT=3306
DB_NAME=filmapi_db
DB_USER=root
DB_PASSWORD=
DB_USE_AUTODETECT=true
DB_SERVER_VERSION=10.11.0-mariadb

DEFAULT_COVER_IMAGE_PATH=/media/defaults/cover-default.jpg

JWT_SECRET_KEY=your-super-secret-key-min-32-characters
JWT_ISSUER=FilmAPI
JWT_AUDIENCE=FilmFrontend
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=provafilmhub@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=provafilmhub@gmail.com

EXTERNAL_AUTH_GOOGLE_CLIENT_ID=
EXTERNAL_AUTH_GOOGLE_CLIENT_SECRET=
EXTERNAL_AUTH_GITHUB_CLIENT_ID=
EXTERNAL_AUTH_GITHUB_CLIENT_SECRET=
EXTERNAL_AUTH_MICROSOFT_CLIENT_ID=
EXTERNAL_AUTH_MICROSOFT_CLIENT_SECRET=
EXTERNAL_AUTH_MICROSOFT_TENANT_ID=common
EXTERNAL_AUTH_BACKEND_BASE_URL=https://filmhub-api.delightfuldune-f7916078.francecentral.azurecontainerapps.io

# Produzione: lista origins frontend consentiti (separati da virgola)
# Esempio: CORS_ALLOWED_ORIGINS=https://filmhub.it,https://app.filmhub.it
CORS_ALLOWED_ORIGINS=

# Opzionale: override esplicito della direttiva CSP `connect-src`.
# Esempio: CSP_CONNECT_SRC='self' https://app.filmhub.it https://api.stripe.com
CSP_CONNECT_SRC=

# Opzionale: lista IP di reverse proxy fidati (separati da virgola)
# Esempio: TRUSTED_PROXIES=10.0.0.10,10.0.0.11
TRUSTED_PROXIES=

# Google Places (New) API key per recupero automatico foto reali cinema
GOOGLE_MAPS_API_KEY=
